# npm v10's strict peer resolver rejects several pinned (often prerelease)
# Novasama host-API versions used across this monorepo against the peer
# ranges their packages declare (e.g. `@novasamatech/host-api-wrapper`'s
# peer on `@novasamatech/host-api`). Same workaround the t3rminal monorepo
# uses.
legacy-peer-deps=true
