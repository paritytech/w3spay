# Deployed W3SPay merchant registry contract (H160, 0x-prefixed).
# Read by `src/config.ts` → `REGISTRY_ADDRESS`; consumed by
# `hooks/use-merchant-table.ts` to load the chain merchant table.
# Empty / unset: loader skips the chain step and falls back to the cached
# snapshot in `KvStore`; if no cache exists every scan lands on
# "Merchant not in pilot". There is no bundled merchant fallback.

# Product DOTNS identifier (e.g. "myinstance.dot"). Read by `src/config.ts` →
# `host.productDotNs` and used by the host wallet adapter to derive the
# product account. `deploy.sh` also reads this var directly as the
# bulletin-deploy target, so a single env var drives both layers.
# REQUIRED — the build throws and the deploy errors if this is unset.
VITE_DOTNS_PRODUCT_DOMAIN=

# Set to `true` to pass --publish to bulletin-deploy, making the build
# publicly discoverable on the bulletin chain. Omit or set to `false`
# to upload without publishing (dry-run / staging deploys).
BULLETIN_DEPLOY_PUBLISH=false
VITE_NETWORK=paseo-next-v2
VITE_W3SPAY_REGISTRY_ADDRESS=0xfec1497a5fbfc2583ea52bc7504701f95ea4a68a

# Pilot-mode merchant id used for TSE-only scans. A bare TSE receipt
# carries the till's `kassenSerial` but no `merchantId`, so every scan
# resolves against the on-chain `W3SPayRegistry` as
# `(pilotMerchantId, kassenSerial)`. Default is `funkhaus`. Override per
# environment; pilot operators must register each till under this pair.
VITE_W3SPAY_PILOT_MERCHANT_ID=funkhaus

# Dev-only manual-payment override. When `true` (case-insensitive — also
# accepts `1`, `yes`), the scanner screen surfaces a small "manual pay"
# button that opens a form taking a raw AccountId32 hex destination + CASH
# amount, and runs the same `host.paymentRequest` path the TSE scan
# does. Use for testing RFC-0006 on Android while the camera host hook
# is still missing. NEVER enable in a public deploy.
VITE_W3SPAY_DEV_PAYMENT_OVERRIDE=false

# Supported runtime platforms (comma-separated, default: mobile).
# Controls which environments are allowed to load the full app — any other
# platform shows the "Use Polkadot Mobile" gate screen without initialising
# the host bridge or auth hooks.
#
# Valid values: mobile, desktop, desktop-app, dotli
#   mobile       — Polkadot Mobile native webview  (default, always include)
#   desktop      — Standalone desktop browser       (for internal dev/testing)
#   desktop-app  — Polkadot Desktop Electron app
#   dotli        — dot.li web app iframe
#
# Example: unlock desktop for local dev
# VITE_SUPPORTED_PLATFORMS=mobile,desktop
VITE_SUPPORTED_PLATFORMS=mobile

# ─── Telemetry ──────────────────────────────────────────────────────
#
# Sentry-backed productivity telemetry — journey tracking for the
# customer-pay flow plus error capture. The MASTER SWITCH is in code
# (`apps/w3spay/src/config.ts → telemetry.enabled`), not env, so a
# build can be shipped with telemetry off without touching deploy
# scripts. The env vars below tune behaviour when telemetry IS on.
#
# Empty / unset DSN: console-only mode. The tracker logs the
# `[Journey:*]` waterfall to dev tools but nothing leaves the device.
# Set a DSN to enable real upload to Sentry.
VITE_W3SPAY_SENTRY_DSN=

# Sentry environment label. Defaults to the Vite build mode
# (`development` / `production`). Override for staging / pilot deploys.
VITE_W3SPAY_SENTRY_ENV=development
VITE_W3SPAY_SENTRY_ENABLED=false

# Traces sample rate (0..1). Defaults to 1.0 — every customer-pay
# journey ships a span. Lower this for high-volume deploys.
VITE_W3SPAY_SENTRY_TRACES_SAMPLE_RATE=1.0
